# Web FTP Client — environment overrides
# Copy to .env and edit as needed.
#
# On ZimaOS / CasaOS when imported via the App Store, these variables are
# auto-populated from /etc/casaos/env. For a manual `docker compose` run
# outside CasaOS, the values below are the documented defaults.

# CasaOS AppData folder name (subdir of /DATA/AppData/)
AppID=web-ftp-client

# Host port the UI is exposed on
WEBUI_PORT=8089

# Encryption key for stored credentials. 'auto' → backend generates one on
# first start and persists it to /app/data/encryption.key
ENCRYPTION_KEY=auto

# User/group the container runs as (must own /DATA/AppData/$AppID on the host)
PUID=1000
PGID=1000

# Timezone inside the container
TZ=Europe/Berlin
